###############################################################################
# Vaidyah Platform - Secrets Template
#
# WARNING: This file contains PLACEHOLDER values only. Do NOT commit real
# secrets to version control.
#
# PRODUCTION RECOMMENDATION:
#   Use the External Secrets Operator (ESO) with AWS Secrets Manager to
#   automatically sync secrets into the cluster. See the ExternalSecret
#   resource defined below as the preferred production approach.
#
# For local/dev usage only, you can apply this file after replacing
# placeholders with base64-encoded values:
#   echo -n 'your-value' | base64
###############################################################################
apiVersion: v1
kind: Secret
metadata:
  name: vaidyah-secrets
  namespace: vaidyah
  labels:
    app.kubernetes.io/name: vaidyah-secrets
    app.kubernetes.io/part-of: vaidyah
    app.kubernetes.io/component: configuration
  annotations:
    # Remind operators this is a template
    vaidyah.health/secret-source: "template - replace with External Secrets Operator in production"
type: Opaque
data:
  # ---------------------------------------------------------------------------
  # Database
  # Base64-encoded placeholder: echo -n 'postgresql://user:pass@host:5432/vaidyah' | base64
  # ---------------------------------------------------------------------------
  DATABASE_URL: cGxhY2Vob2xkZXItZGF0YWJhc2UtdXJs

  # ---------------------------------------------------------------------------
  # Redis / ElastiCache
  # Base64-encoded placeholder: echo -n 'rediss://user:pass@host:6379' | base64
  # ---------------------------------------------------------------------------
  REDIS_URL: cGxhY2Vob2xkZXItcmVkaXMtdXJs

  # ---------------------------------------------------------------------------
  # JWT / Authentication
  # Base64-encoded placeholder: echo -n 'change-me-jwt-secret-256-bit-minimum' | base64
  # ---------------------------------------------------------------------------
  JWT_SECRET: cGxhY2Vob2xkZXItand0LXNlY3JldA==

  # ---------------------------------------------------------------------------
  # AWS Cognito
  # Base64-encoded placeholders
  # ---------------------------------------------------------------------------
  COGNITO_USER_POOL_ID: cGxhY2Vob2xkZXItdXNlci1wb29sLWlk
  COGNITO_CLIENT_ID: cGxhY2Vob2xkZXItY2xpZW50LWlk
  COGNITO_CLIENT_SECRET: cGxhY2Vob2xkZXItY2xpZW50LXNlY3JldA==

  # ---------------------------------------------------------------------------
  # OpenSearch Credentials (if not using IAM-based auth)
  # ---------------------------------------------------------------------------
  OPENSEARCH_USERNAME: cGxhY2Vob2xkZXItb3MtdXNlcm5hbWU=
  OPENSEARCH_PASSWORD: cGxhY2Vob2xkZXItb3MtcGFzc3dvcmQ=

  # ---------------------------------------------------------------------------
  # Encryption Key (for PHI at-rest encryption in application layer)
  # ---------------------------------------------------------------------------
  ENCRYPTION_KEY: cGxhY2Vob2xkZXItZW5jcnlwdGlvbi1rZXk=

  # ---------------------------------------------------------------------------
  # API Keys for External Services
  # ---------------------------------------------------------------------------
  OPENAI_API_KEY: cGxhY2Vob2xkZXItb3BlbmFpLWtleQ==

---
