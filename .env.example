# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Amazon Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=

# Amazon RDS (PostgreSQL)
DATABASE_URL=postgresql://vaidyah:password@localhost:5432/vaidyah
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vaidyah
DB_USER=vaidyah
DB_PASSWORD=

# Amazon DynamoDB
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_PREFIX=vaidyah_

# Amazon S3
S3_BUCKET_VOICE=vaidyah-voice-recordings
S3_BUCKET_DOCS=vaidyah-documents
S3_BUCKET_IMAGES=vaidyah-medical-images

# Amazon OpenSearch
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INDEX_TRIALS=clinical_trials

# AWS Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=ap-south-1

# AWS Transcribe
TRANSCRIBE_REGION=ap-south-1
TRANSCRIBE_MEDICAL_VOCABULARY=vaidyah-medical-vocab

# Amazon Polly
POLLY_REGION=ap-south-1

# AWS SageMaker Endpoints
SAGEMAKER_PROSODY_ENDPOINT=vaidyah-prosody-analysis
SAGEMAKER_CONTRADICTION_ENDPOINT=vaidyah-contradiction-detect
SAGEMAKER_TRIAL_MATCH_ENDPOINT=vaidyah-trial-matching

# ABDM (Ayushman Bharat Digital Mission)
ABDM_BASE_URL=https://dev.abdm.gov.in
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_AUTH_URL=https://dev.ndhm.gov.in/gateway

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Application
NODE_ENV=development
API_PORT=3000
VOICE_SERVICE_URL=http://localhost:8001
NLU_SERVICE_URL=http://localhost:8002
CLINICAL_SERVICE_URL=http://localhost:3001
TRIAL_SERVICE_URL=http://localhost:8003
INTEGRATION_SERVICE_URL=http://localhost:3002

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# Encryption
ENCRYPTION_KEY=
KMS_KEY_ID=
