# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# PostgreSQL
DATABASE_URL=postgresql://vaidyah:password@localhost:5432/vaidyah
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vaidyah
DB_USER=vaidyah
DB_PASSWORD=

# Amazon S3
S3_BUCKET_VOICE=vaidyah-voice-recordings
S3_BUCKET_DOCS=vaidyah-documents
S3_BUCKET_IMAGES=vaidyah-medical-images

# AWS Bedrock (NLU + ML inference)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_ML_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=ap-south-1

# AWS Transcribe
TRANSCRIBE_REGION=ap-south-1
TRANSCRIBE_MEDICAL_VOCABULARY=vaidyah-medical-vocab

# Amazon Polly
POLLY_REGION=ap-south-1

# ABDM (Ayushman Bharat Digital Mission)
ABDM_BASE_URL=https://dev.abdm.gov.in
ABDM_CLIENT_ID=
ABDM_CLIENT_SECRET=
ABDM_AUTH_URL=https://dev.ndhm.gov.in/gateway

# WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Application
NODE_ENV=development
API_PORT=3000
VOICE_SERVICE_URL=http://localhost:8001
NLU_SERVICE_URL=http://localhost:8002
CLINICAL_SERVICE_URL=http://localhost:3001
TRIAL_SERVICE_URL=http://localhost:8003
INTEGRATION_SERVICE_URL=http://localhost:3002

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=1h
REFRESH_TOKEN_EXPIRY=7d

# Encryption
ENCRYPTION_KEY=
KMS_KEY_ID=

# LiveKit (Telemedicine)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=ws://localhost:7880

# Vercel (Web App Deployment)
# Set these in Vercel project environment variables:
# API_GATEWAY_URL=http://<ec2-elastic-ip>:3000
# AUTH_SERVICE_URL=http://<ec2-elastic-ip>:3000
# NEXT_PUBLIC_API_BASE_URL=/api/v1
# NEXT_PUBLIC_AUTH_BASE_URL=/auth
