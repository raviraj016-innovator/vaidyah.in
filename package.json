{
  "name": "vaidyah",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turbo": "^2.3.0"
  },
  "packageManager": "npm@11.7.0",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@vaidyah/web": {
      "react": "19.2.0",
      "react-dom": "19.2.0"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.9"
    },
    "cacache": {
      "tar": "7.5.9"
    },
    "terser-webpack-plugin": {
      "serialize-javascript": "7.0.4"
    }
  }
}
