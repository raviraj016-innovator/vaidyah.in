# =============================================================================
# Production secrets — copy to .env on EC2, NEVER commit .env
# Usage: docker compose -f docker-compose.prod.yml --env-file .env up -d --build
# =============================================================================

# ---- Database (RDS) ----
DB_HOST=vaidyah-prod-postgres.XXXXXXXX.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=vaidyah
DB_USER=vaidyah_admin
# Use $$ to escape a literal $ in Docker Compose .env files
DB_PASSWORD=CHANGE_ME
# URL-encoded password (used in DATABASE_URL construction in docker-compose.prod.yml)
# Encode special chars: $ → %24, ] → %5D, ( → %28, ) → %29, ! → %21, < → %3C, + → %2B
DB_PASSWORD_ENCODED=CHANGE_ME

# ---- Auth ----
JWT_SECRET=CHANGE_ME

# ---- S3 ----
S3_AUDIO_BUCKET=vaidyah-prod-voice-recordings

# ---- LiveKit ----
LIVEKIT_API_KEY=CHANGE_ME
LIVEKIT_API_SECRET=CHANGE_ME
LIVEKIT_WS_URL=ws://YOUR_EC2_PUBLIC_IP:7880

# ---- CORS (comma-separated, used by Node services: api-gateway, telemedicine) ----
# Python services have their CORS origins hardcoded in docker-compose.prod.yml
CORS_ORIGINS=https://vaidyah.in,https://vaidyah.vercel.app
